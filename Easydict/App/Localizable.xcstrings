        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "如果您想要還原，請在查詢視窗中使用快速鍵 Cmd + , 開啟設定頁面，然後取消 [隱藏狀態列圖示] 選項。"
          }
        }
      }
    },
