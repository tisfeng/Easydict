    "service.codex_cli.enable_risk_alert.message" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This service uses your locally installed and signed-in official Codex CLI. It does not use OAuth, private APIs, or proxy workarounds. OpenAI may change CLI policies or account rules in the future. Continue only if you understand and accept the potential account or policy risk."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "このサービスは、ローカルにインストールされサインイン済みの公式 Codex CLI を使用します。OAuth、非公開 API、プロキシによる回避策は使用しません。OpenAI は今後 CLI のポリシーやアカウント規則を変更する可能性があります。潜在的なアカウントやポリシーのリスクを理解し受け入れる場合のみ続行してください。"
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Táto služba používa lokálne nainštalované a prihlásené oficiálne Codex CLI. Nepoužíva OAuth, súkromné API ani proxy obchádzky. OpenAI môže v budúcnosti zmeniť pravidlá CLI alebo účtov. Pokračujte iba vtedy, ak rozumiete možnému riziku pre účet alebo pravidlá a prijímate ho."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "此服务使用你本机已安装并已登录的官方 Codex CLI，不使用 OAuth、私有 API 或代理绕行方案。OpenAI 未来可能调整 CLI 政策或账号规则。仅当你理解并接受潜在的账号或政策风险时再继续。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "此服務使用你本機已安裝且已登入的官方 Codex CLI，不使用 OAuth、私有 API 或代理繞行方案。OpenAI 未來可能調整 CLI 政策或帳號規則。僅當你理解並接受潛在的帳號或政策風險時再繼續。"
          }
        }
      }
    },
