        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "元に戻すには、ショートカット `Cmd + ,` でクエリウィンドウの設定ページを開き、[ステータスバーアイコンを非表示] オプションを解除してください。"
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pre obnovenie otvor stránku s nastaveniami v okne prekladu použitím skratky ⌘ + , a potom zruš možnosť [Skryť ikonu v lište]."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "如需恢复，请在查词窗口使用快捷键 `Cmd + ,` 打开设置页，然后取消【隐藏菜单栏图标】选项。"
          }
